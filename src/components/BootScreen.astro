---
import { executeCommand } from "../lib/engine";
---

<div class="Boot">
    <!-- Header -->
    <header class="Header">
        <div class="HeaderInner">
            <button class="Button Button--switch">
                <span class="material-symbols-outlined ButtonIndicator">settings_input_component</span>
                <span class="ButtonText">Switch UI</span>
            </button>
        </div>
        <div class="Banner">
            <div class="BannerStack" aria-hidden="true">
                <pre class="BannerText BannerText--sizer">
в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—
в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘      в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
