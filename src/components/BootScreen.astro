<!-- Header -->
<header class="Header">
    <div class="HeaderInner">
    <button class="Button Button--switch">
        <span class="material-symbols-outlined ButtonIndicator">settings_input_component</span>
        <span class="ButtonText">Switch UI</span>
    </button>
    </div>
</header>

<!-- Boot Card / Terminal -->
<section class="Terminal">
    <div class="TerminalWindow">

    <!-- Window Controls -->
    <div class="TerminalControls">
        <span class="TerminalDot TerminalDot--red"></span>
        <span class="TerminalDot TerminalDot--gray"></span>
        <span class="TerminalDot TerminalDot--blue"></span>
    </div>

    <!-- Terminal Content -->
    <div class="TerminalBody">
        <div class="TerminalLog">

        <div class="TerminalLine">
            <span class="TerminalLineNumber">01</span>
            <p class="TerminalText">
            <span class="TerminalTag">[INFO]</span>
            booting rishi.sh...
            </p>
        </div>

        <div class="TerminalLine">
            <span class="TerminalLineNumber">02</span>
            <p class="TerminalText">
            <span class="TerminalTag">[SYS]</span>
            initializing modules...
            </p>
        </div>

        <div class="TerminalLine">
            <span class="TerminalLineNumber">03</span>
            <p class="TerminalText">
            <span class="TerminalTag">[FS]</span>
            loading projects...
            </p>
        </div>

        <div class="TerminalLine TerminalLine--success">
            <span class="TerminalLineNumber">04</span>
            <p class="TerminalText">READY.</p>
        </div>

        <div class="TerminalLine TerminalLine--hint">
            <span class="TerminalLineNumber">05</span>
            <p class="TerminalText">
            Type <span class="TerminalCommand">'help'</span> to begin.
            </p>
        </div>

        </div>
    </div>

    </div>
</section>